# ─────────────────────────────────────────────────────────────────────────────
#  ESI — Environment Variables
#  Copy this file to .env and fill in your keys before running Docker.
#
#      cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# FRED API key — get free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Gemini API key — get free at https://aistudio.google.com/app/apikey
# Only needed for the dashboard AI chat feature
GEMINI_API_KEY=your_gemini_api_key_here
