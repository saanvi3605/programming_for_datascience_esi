# Git
.git
.gitignore

# Python cache
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.egg-info

# Virtual environments
.venv
venv
env

# Environment secrets — never bake into image
.env

# Results and data — mounted as volumes at runtime
# (comment these out if you want data baked into the image)
data/raw/*
data/processed/*
results/figures/*
results/tables/*

# Notebooks
notebooks/

# OS files
.DS_Store
Thumbs.db
